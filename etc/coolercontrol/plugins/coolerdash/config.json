{
  "_comment": "CoolerDash Plugin Configuration - All values with defaults",

  "daemon": {
    "address": "http://localhost:11987",
    "access_token": "",
    "_comment_token": "Create a token in CoolerControl UI → Access Protection. Format: cc_<uuid>."
  },

  "device_detection": {
    "mode": "strict",
    "allowlist": "",
    "blocklist": "mainboard\nmotherboard\nchipset"
  },

  "paths": {
    "images": "/etc/coolercontrol/plugins/coolerdash",
    "image_coolerdash": "/etc/coolercontrol/plugins/coolerdash/coolerdash.png",
    "image_background": "",
    "image_shutdown": "/etc/coolercontrol/plugins/coolerdash/shutdown.png"
  },

  "display": {
    "mode": "circle",
    "circle_switch_interval": 5,
    "circle_show_extra_info": true,
    "refresh_interval": 2.5,
    "brightness": 80,
    "orientation": 0,
    "background_image_fit": "cover",
    "background_overlay_opacity": 0.0,
    "width": 0,
    "height": 0,
    "content_scale_factor": 0.98,
    "sensor_slot_1": "cpu",
    "sensor_slot_2": "liquid",
    "sensor_slot_3": "gpu"
  },

  "layout": {
    "bar_height": 24,
    "bar_width": 98,
    "bar_gap": 12,
    "bar_border": 1.0,
    "bar_opacity": 1.0,
    "bar_border_enabled": 1,
    "label_margin_left": 1,
    "label_margin_bar": 1,
    "bar_height_1": 0,
    "bar_height_2": 0,
    "bar_height_3": 0
  },

  "colors": {
    "bar_background": { "r": 52, "g": 52, "b": 52 },
    "bar_border": { "r": 192, "g": 192, "b": 192 },
    "font_temp": { "r": 255, "g": 255, "b": 255 },
    "font_label": { "r": 200, "g": 200, "b": 200 }
  },

  "font": {
    "face": "Roboto Black",
    "size_temp": 0.0,
    "size_labels": 0.0,
    "font_growth_factor": 1.33
  },

  "sensors": {
    "cpu": {
      "threshold_1": 55.0,
      "threshold_2": 65.0,
      "threshold_3": 75.0,
      "max_scale": 115.0,
      "threshold_1_color": { "r": 0, "g": 255, "b": 0 },
      "threshold_2_color": { "r": 255, "g": 140, "b": 0 },
      "threshold_3_color": { "r": 255, "g": 70, "b": 0 },
      "threshold_4_color": { "r": 255, "g": 0, "b": 0 },
      "offset_x": 0,
      "offset_y": 0
    },
    "gpu": {
      "threshold_1": 55.0,
      "threshold_2": 65.0,
      "threshold_3": 75.0,
      "max_scale": 115.0,
      "threshold_1_color": { "r": 0, "g": 255, "b": 0 },
      "threshold_2_color": { "r": 255, "g": 140, "b": 0 },
      "threshold_3_color": { "r": 255, "g": 70, "b": 0 },
      "threshold_4_color": { "r": 255, "g": 0, "b": 0 },
      "offset_x": 0,
      "offset_y": 0
    },
    "liquid": {
      "threshold_1": 30.0,
      "threshold_2": 35.0,
      "threshold_3": 40.0,
      "max_scale": 55.0,
      "threshold_1_color": { "r": 0, "g": 255, "b": 0 },
      "threshold_2_color": { "r": 255, "g": 140, "b": 0 },
      "threshold_3_color": { "r": 255, "g": 70, "b": 0 },
      "threshold_4_color": { "r": 255, "g": 0, "b": 0 },
      "offset_x": 0,
      "offset_y": 0
    }
  },

  "positioning": {
    "degree_spacing": 16,
    "label_offset_x": 0,
    "label_offset_y": 0
  }
}
